---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <section class="py-16 text-center">
    <h1 class="font-display text-4xl sm:text-5xl font-bold mb-4 text-text-primary">404</h1>
    <p class="text-lg text-text-secondary mb-8 max-w-md mx-auto">
      The page you're looking for doesn't exist. It might have been moved, deleted, or maybe the URL has a typo.
    </p>
    <a href="/" class="text-accent hover:underline font-medium">Go back home →</a>
  </section>
</BaseLayout>
