---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getSlug } from '../utils/slug';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = posts.slice(0, 3);

const formatShortDate = (date: Date) => date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<BaseLayout title="Home">
  <div class="min-h-[60vh]">
    <section class="py-12 sm:py-16">
      <p class="text-sm font-medium text-accent mb-3">Toni Esteso — Senior Software Engineer</p>
      <h1 class="font-display text-4xl sm:text-5xl font-bold leading-tight mb-6">
        Building systems that actually <span class="text-accent">hold up</span>.
      </h1>

      <p class="text-lg text-muted max-w-md">
        I write about the engineering tradeoffs, the messy parts of development,
        and what it takes to ship code that works in production.
      </p>
    </section>
    
    <div class="w-full h-1 bg-accent rounded-full mb-8"></div>
    
    <section class="border-t border-muted/20 pt-8">
      <h2 class="font-display text-xl font-semibold mb-6">Recent Posts</h2>

      <ul class="space-y-4">
        {recentPosts.map((post) => (
          <li class="flex gap-4 items-baseline">
            <time class="text-xs text-muted w-20 shrink-0" datetime={post.data.pubDate.toISOString()}>
              {formatShortDate(post.data.pubDate)}
            </time>
            <a href={`/blog/${getSlug(post.id)}`} class="font-medium hover:text-accent transition-colors">
              {post.data.title}
            </a>
          </li>
        ))}
      </ul>

      <p><a href="/blog" class="text-accent hover:underline">View all posts →</a></p>
    </section>
  </div>
</BaseLayout>