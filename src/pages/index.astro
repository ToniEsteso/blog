---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = posts.slice(0, 3);
---

<BaseLayout title="Home">
  <p class="text-xl font-medium text-text-primary mb-6 font-display">I write about building production software - the engineering tradeoffs, the messy parts of development, and what it takes to ship code that actually works.</p>

  <p class="mb-4">This is where I share what I'm learning along the way.</p>

  <h2 class="text-xl font-semibold mt-8 mb-4 text-text-primary font-display">Recent Posts</h2>

  <ul class="list-none p-0">
    {recentPosts.map((post) => (
      <li class="mb-4">
        <span class="text-[#888] text-sm mr-2 inline-block min-w-[100px] text-right">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
        <a href={`/blog/${post.id.split('/').pop().replace('.md', '')}`} class="font-medium text-blue-600 hover:underline">{post.data.title}</a>
      </li>
    ))}
  </ul>

  <p><a href="/blog" class="text-blue-600 hover:underline">View all posts →</a></p>
</BaseLayout>