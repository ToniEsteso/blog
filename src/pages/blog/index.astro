---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function estimateReadingTime(markdown: string): number {
  // Remove frontmatter
  let text = markdown.replace(/^---[\s\S]*?---/, '');
  // Remove fenced code blocks
  text = text.replace(/```[\s\S]*?```/g, '');
  // Remove inline code
  text = text.replace(/`[^`]+`/g, '');
  // Remove HTML tags
  text = text.replace(/<[^>]+>/g, '');
  // Remove markdown links/images syntax, keep text
  text = text.replace(/!?\[[^\]]*\]\([^)]*\)/g, '');
  text = text.replace(/!?\[[^\]]*\]\[[^\]]*\]/g, '');
  // Remove markdown formatting characters
  text = text.replace(/[*_#~>-]/g, '');
  // Count words
  const words = text.trim().split(/\s+/).filter(Boolean);
  return Math.ceil(words.length / 200);
}

const postsWithReadingTime = posts.map(post => ({
  post,
  readingTime: estimateReadingTime(post.body)
}));
---

<BaseLayout title="Blog">
  <h1 class="text-3xl font-bold mb-8 text-text-primary font-display">Blog</h1>

  {posts.length > 0 ? (
    <div class="grid gap-4">
      {postsWithReadingTime.map(({ post, readingTime }) => (
        <PostCard post={post} readingTime={readingTime} />
      ))}
    </div>
  ) : (
    <p class="text-muted">No posts yet. Check back soon.</p>
  )}
</BaseLayout>