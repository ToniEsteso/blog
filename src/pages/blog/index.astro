---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog">
  <h1 class="text-3xl font-bold mb-4 text-text-primary font-display">Blog</h1>

  <ul class="list-none p-0">
    {posts.map((post) => (
      <li class="mb-4">
        <span class="text-[#888] text-sm mr-2 inline-block min-w-[100px] text-right">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
        <a href={`/blog/${post.id.split('/').pop().replace('.md', '')}`} class="font-medium text-blue-600 hover:underline">{post.data.title}</a>
      </li>
    ))}
  </ul>

  {posts.length === 0 && <p>No posts yet. Check back soon.</p>}
</BaseLayout>