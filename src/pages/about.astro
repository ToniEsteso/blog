---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section class="py-8">
    <h1 class="font-display text-3xl sm:text-4xl font-bold mb-4 text-text-primary">About</h1>
    <p class="text-lg text-text-secondary mb-6 max-w-prose">
      I'm a software engineer at Mews building production systems that actually hold up.
    </p>
  </section>

  <section class="py-8 border-t border-muted/20">
    <h2 class="font-display text-xl sm:text-2xl font-semibold mb-4 text-text-primary">Background</h2>
    <div class="prose prose-neutral max-w-prose">
      <p class="text-text-secondary leading-relaxed">
        Started in software development, moved into building production systems when I saw how much potential there was to automate and improve workflows. Now my main focus is the gap between "it works locally" and "it runs reliably in production."
      </p>
    </div>
  </section>

  <section class="py-8 border-t border-muted/20">
    <h2 class="font-display text-xl sm:text-2xl font-semibold mb-4 text-text-primary">What I Do</h2>
    <div class="prose prose-neutral max-w-prose">
      <p class="text-text-secondary leading-relaxed">
        Building, deploying, and maintaining production systems. Writing code that doesn't make the next person curse my name.
      </p>
    </div>
  </section>

  <section class="py-8 border-t border-muted/20">
    <h2 class="font-display text-xl sm:text-2xl font-semibold mb-4 text-text-primary">Connect</h2>
    <ul class="flex gap-4 text-sm">
      <li>
        <a href="https://linkedin.com/in/toni-esteso" class="flex items-center gap-2 text-text-secondary hover:text-accent transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>