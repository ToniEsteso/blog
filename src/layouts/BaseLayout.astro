---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Software engineer building production systems' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Lora:wght@400;500;600&display=swap" rel="stylesheet">
  <title>{title}</title>
  <meta name="description" content={description}>
</head>
<body class="font-body leading-relaxed text-text-primary max-w-[680px] mx-auto px-6 bg-background">
  <header class="py-8 border-b border-muted/30 mb-8">
    <nav class="flex gap-6">
      <a href="/" class="no-underline text-text-secondary font-medium hover:text-text-primary transition-colors duration-200">Home</a>
      <a href="/about" class="no-underline text-text-secondary font-medium hover:text-text-primary transition-colors duration-200">About</a>
      <a href="/blog" class="no-underline text-text-secondary font-medium hover:text-text-primary transition-colors duration-200">Blog</a>
    </nav>
  </header>

  <main class="min-h-[60vh]">
    <slot />
  </main>

  <footer class="py-8 mt-12 border-t border-muted/30 text-sm text-text-secondary">
    <p>&copy; {new Date().getFullYear()} Toni Esteso. <a href="https://www.linkedin.com/in/toni-esteso/" class="text-accent hover:underline">LinkedIn</a></p>
  </footer>
</body>
</html>