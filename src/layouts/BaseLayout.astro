---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Software engineer building production systems' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
</head>
<body class="font-sans leading-relaxed text-[#333] max-w-[680px] mx-auto px-6 bg-white">
  <header class="py-8 border-b border-gray-200 mb-8">
    <nav class="flex gap-6">
      <a href="/" class="no-underline text-[#666] font-medium hover:text-[#111] transition-colors duration-200">Home</a>
      <a href="/about" class="no-underline text-[#666] font-medium hover:text-[#111] transition-colors duration-200">About</a>
      <a href="/blog" class="no-underline text-[#666] font-medium hover:text-[#111] transition-colors duration-200">Blog</a>
    </nav>
  </header>

  <main class="min-h-[60vh]">
    <slot />
  </main>

  <footer class="py-8 mt-12 border-t border-gray-200 text-sm text-[#666]">
    <p>&copy; {new Date().getFullYear()} Toni Esteso. <a href="https://www.linkedin.com/in/toni-esteso/" class="text-blue-600 hover:underline">LinkedIn</a></p>
  </footer>
</body>
</html>