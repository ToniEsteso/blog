---
import '../styles/global.css';
import { SITE } from '../config';

interface Props {
  title: string;
  description?: string;
}

const { title, description = SITE.defaultDescription } = Astro.props;

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Lora:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E👤%3C/text%3E%3C/svg%3E" />
  <title>{title}</title>
  <meta name="description" content={description}>

  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={Astro.url.href}>

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <style>
    html { background-color: #e8e0c1; }
  </style>
</head>
<body class="font-body leading-relaxed text-text-primary max-w-[680px] mx-auto px-6 bg-background min-h-screen flex flex-col">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-background focus:text-text-primary focus:px-4 focus:py-2 focus:rounded focus:border focus:border-accent">Skip to content</a>
  <!--
    The `body-start` slot is rendered immediately after the skip-link and before
    the header. This is where ProgressBar.astro injects itself via
    `<ProgressBar slot="body-start" />`. Using a named slot keeps the progress
    bar outside of `<main>` and `<header>` so it can be `position: fixed` at the
    very top of the viewport without interfering with document semantics.
  -->
  <slot name="body-start" />
  <header class="border-b border-muted/20 bg-background/80 backdrop-blur-sm sticky top-0 z-50">
    <nav class="py-4 flex items-center justify-between">
      <a href="/" class="font-display text-lg font-medium tracking-tight text-text-primary hover:text-accent transition-colors">
        {SITE.title}
      </a>
      <div class="flex gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === link.href || (currentPath === '/' && link.href === '/')
                ? 'text-accent'
                : 'text-text-secondary hover:text-text-primary'
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>
  </header>

  <main id="main" class="min-h-[60vh] animate-fade-in-delay-1 flex-grow">
    <slot />
  </main>

  <footer class="border-t border-muted/20 py-8 mt-12">
    <div class="flex flex-col sm:flex-row gap-4 justify-between text-sm text-text-secondary">
      <p>&copy; {new Date().getFullYear()} {SITE.author}</p>
      <div class="flex flex-col sm:flex-row gap-4 sm:items-center">
        <a href={`mailto:${SITE.email}`} class="hover:text-text-primary transition-colors">{SITE.email}</a>
        <div class="flex gap-4">
          <a href="/rss.xml" class="hover:text-text-primary transition-colors">RSS</a>
          <a href={SITE.social.github} target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">GitHub</a>
          <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors">LinkedIn</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
