---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Software engineer building production systems' } = Astro.props;

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif&family=Lora:wght@400;500;600&display=swap" rel="stylesheet">
  <title>{title}</title>
  <meta name="description" content={description}>
</head>
<body class="font-body leading-relaxed text-text-primary max-w-[680px] mx-auto px-6 bg-background">
  <header class="border-b border-muted/20 bg-background/80 backdrop-blur-sm sticky top-0 z-50">
    <nav class="py-4 flex items-center justify-between">
      <a href="/" class="font-display text-lg font-medium tracking-tight text-text-primary hover:text-accent transition-colors">
        Toni Esteso
      </a>
      <div class="flex gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === link.href || (currentPath === '/' && link.href === '/')
                ? 'text-accent'
                : 'text-text-secondary hover:text-text-primary'
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>
  </header>

  <main class="min-h-[60vh]">
    <slot />
  </main>

  <footer class="border-t border-muted/20 py-8 mt-12">
    <div class="flex flex-col sm:flex-row gap-4 justify-between text-sm text-text-secondary">
      <p>&copy; {new Date().getFullYear()} Toni Esteso</p>
      <div class="flex gap-4">
        <a href="/rss.xml" class="hover:text-text-primary transition-colors">RSS</a>
        <a href="https://linkedin.com/in/toni-esteso" class="hover:text-text-primary transition-colors">LinkedIn</a>
      </div>
    </div>
  </footer>
</body>
</html>