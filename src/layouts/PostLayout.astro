---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  date: Date;
  category: string;
}

const { title, description, date, category } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} - Toni Esteso`} description={description}>
  <article class="prose prose-neutral max-w-none">
    <h1 class="text-3xl font-bold mb-4 text-[#111] font-display">{title}</h1>
    <p class="text-[#888] text-sm mb-6">{formattedDate} · {category}</p>
    <slot />
  </article>
</BaseLayout>